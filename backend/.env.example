# ──────────────────────────────────────────────
# Backend Environment Variables — LOCAL DEV
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# App
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info

# Security — CHANGE THIS before going to production!
JWT_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# Database — SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite:///./maintenance.db

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional LLM API Keys (leave blank if unused)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Simulator
SIMULATOR_INTERVAL_SECONDS=2.0

# Token expiry (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440
